{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course",
    "description": "Educational courses with modules and lessons"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "modules": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::course-module.course-module",
      "mappedBy": "course"
    },
    "price": {
      "type": "component",
      "repeatable": false,
      "component": "shared.pricing-tier"
    },
    "accessTier": {
      "type": "enumeration",
      "enum": ["free", "subscriber", "member"],
      "default": "free"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag"
    },
    "draft": {
      "type": "boolean",
      "default": false
    }
  }
}
