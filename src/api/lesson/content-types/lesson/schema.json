{
  "kind": "collectionType",
  "collectionName": "lessons",
  "info": {
    "singularName": "lesson",
    "pluralName": "lessons",
    "displayName": "Lesson",
    "description": "An individual lesson within a course module"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "body": {
      "type": "dynamiczone",
      "components": [
        "rich-content.text-block",
        "rich-content.code-block",
        "rich-content.image-block",
        "rich-content.video-embed",
        "rich-content.callout"
      ]
    },
    "videoURL": {
      "type": "string"
    },
    "duration": {
      "type": "integer"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "module": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course-module.course-module",
      "inversedBy": "lessons"
    },
    "free": {
      "type": "boolean",
      "default": false
    }
  }
}
