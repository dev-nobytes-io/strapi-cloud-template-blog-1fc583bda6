{
  "kind": "collectionType",
  "collectionName": "case_studies",
  "info": {
    "singularName": "case-study",
    "pluralName": "case-studies",
    "displayName": "Case Study",
    "description": "Client and project case studies"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "client": {
      "type": "string"
    },
    "outcome": {
      "type": "string"
    },
    "challenge": {
      "type": "text"
    },
    "solution": {
      "type": "text"
    },
    "result": {
      "type": "text"
    },
    "body": {
      "type": "dynamiczone",
      "components": [
        "rich-content.text-block",
        "rich-content.code-block",
        "rich-content.image-block",
        "rich-content.video-embed",
        "rich-content.callout"
      ]
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "industry": {
      "type": "string"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "membersOnly": {
      "type": "boolean",
      "default": false
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
