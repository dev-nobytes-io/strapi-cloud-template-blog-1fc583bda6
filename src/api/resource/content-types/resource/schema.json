{
  "kind": "collectionType",
  "collectionName": "resources",
  "info": {
    "singularName": "resource",
    "pluralName": "resources",
    "displayName": "Resource",
    "description": "Downloadable tools, templates, scripts and checklists"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "file": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images", "files", "videos"]
    },
    "externalURL": {
      "type": "string"
    },
    "type": {
      "type": "enumeration",
      "enum": ["script", "template", "checklist", "tool"]
    },
    "accessTier": {
      "type": "enumeration",
      "enum": ["public", "registered", "member"],
      "default": "public"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag"
    }
  }
}
